# ---------------------------------------------------------------------------
# GGU environment template
# Copy this file to `.env.local` and fill in values for your environment.
# `.env.local` is loaded by Next.js for local development and is git-ignored.
# ---------------------------------------------------------------------------

# --- Supabase -------------------------------------------------------------
# Project settings -> API -> Project URL and anon public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL of this deployment.
# Used to build the OAuth callback URL (`<SITE_URL>/auth/callback`).
# For local dev leave blank or set to http://localhost:3000.
# On Vercel this is inferred from VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=

# --- Database (Drizzle / Postgres) ----------------------------------------
# Pooled connection used by the app at runtime (e.g. Supabase pgbouncer 6543).
DATABASE_URL=

# Optional direct (non-pooled) connection used by `drizzle-kit` for migrations.
# Falls back to DATABASE_URL if unset.
DIRECT_URL=
