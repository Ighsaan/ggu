# Template for `supabase/.env`. Copy this file to `supabase/.env` and fill in
# your real values. `supabase/.env` is git-ignored; this example is committed
# so teammates know which variables the local stack needs.
#
# `supabase start` does NOT auto-load this file. Use `npm run supabase:start`
# (defined in the root package.json) which sources it before invoking the CLI.
#
# Get Google OAuth credentials from Google Cloud Console → APIs & Services →
# Credentials → OAuth 2.0 Client IDs → Web application.
#
# Authorized redirect URI (set in Google Cloud):
#   http://127.0.0.1:54321/auth/v1/callback

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
